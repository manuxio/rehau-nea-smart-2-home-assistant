# --- device ----------------------------------------------------------------
DEVICE_URL=http://10.0.0.1
# live: scrape the real device. mock: serve from seed data for dev without LAN access.
DEVICE_MODE=live
# YOUR 8-character installer code (first 8 chars of the device's unique code,
# or printed on the box / commissioning sheet). Required for live mode.
DEVICE_INSTALLER_CODE=
DEVICE_ID=
DEVICE_REQUEST_TIMEOUT_MS=5000
# Cool-down between consecutive device calls. REHAU's TCP socket table is
# small; back-to-back requests can exhaust TIME_WAIT and cause ConnectTimeout.
# 150ms is a good default. Raise to 250-400ms if you still see saturation.
DEVICE_MIN_GAP_MS=150
INSTALLER_MAX_SESSION_S=30

# --- installation ----------------------------------------------------------
# Human-readable name for this REHAU installation. Used as the HA device name
# and slugified into the MQTT topic path so multiple installations can share
# the same broker without colliding (eg. INSTALLATION_NAME=Casa →
# rehau/casa/<deviceId>/...). Keep it short and unique per site.
INSTALLATION_NAME=Casa

# --- http api --------------------------------------------------------------
HTTP_PORT=8080
HTTP_CORS_ORIGINS=
JWT_SECRET=change-me-32-random-bytes-or-more
JWT_TTL=1h
API_USER=admin
# generate with: npm run hashpw -- <your-password>
API_PASSWORD_HASH=$2b$12$replace_me_with_real_bcrypt_hash
ADMIN_ROLE=installer

# --- mqtt (external broker) ------------------------------------------------
MQTT_URL=mqtt://homeassistant.local:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=rehau
MQTT_HA_DISCOVERY=true
MQTT_HA_DISCOVERY_PREFIX=homeassistant

# --- polling ---------------------------------------------------------------
POLL_DASHBOARD_S=30
POLL_ROOMS_S=15
POLL_ROOM_DETAIL_S=60
POLL_MESSAGES_S=300
POLL_IO_S=10
EXPOSE_IO=true
EXPOSE_CALIBRATION=false

# --- room → floor map (UI-only metadata, REHAU does not expose this) -------
# format: roomIndex:floorName, comma-separated
ROOM_FLOORS=0:Piano 1,1:Piano 1,2:Piano Terra,3:Piano Terra

# --- logging ---------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
