{
  "name": "@rehau/bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Node service that bridges the REHAU Nea Smart 2 web UI to REST + SSE + MQTT",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "node --watch --import tsx src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "openapi:emit": "tsx src/scripts/emit-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@rehau/types": "*",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "mqtt": "^5.10.3",
    "pino": "^9.5.0",
    "undici": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.1",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
