# ── dependencies ────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/

# ── build outputs ───────────────────────────────────────────────────
# Inner workspace dist/web folders are regenerated by `npm run build`.
apps/*/dist/
apps/*/web/
packages/*/dist/
*.tsbuildinfo

# The published add-on artifacts ARE tracked — they're what HA installs.
# (No need for an explicit !rehau-bridge/dist/ because the patterns
# above only match apps/* and packages/* — the addon folder is outside
# the workspace globs.) Source maps inside the published bundle would
# double its size for no end-user benefit, so we skip them.
rehau-bridge/dist/*.map
rehau-bridge/web/assets/*.map

# ── env / secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── logs / scratch ──────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
.nyc_output/
.vite/
tests/fixtures/scratch/

# ── editors / OS ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── generated openapi client (regenerated from spec) ────────────────
packages/api-client/src/generated/

# ── design / process docs (not part of the source distribution) ─────
Betterehau-handoff/
Betterehau-handoff.zip
CLAUDE_DESIGN_PROMPT.md
PLAN.md
STATUS.md

# ── stray screenshots at repo root (already in docs/screenshots/) ───
# Scoped to the root with leading "/" so legitimate icons inside e.g.
# apps/mobile/assets/ are still tracked.
/IMG_*.PNG
/IMG_*.png
/image.png
/icon.png
