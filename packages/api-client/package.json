{
  "name": "@rehau/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed REST client auto-generated from the bridge's OpenAPI spec",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "openapi-ts -i ./openapi.json -o ./src/generated -c @hey-api/client-fetch",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@rehau/types": "*"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "typescript": "^5.6.3"
  }
}
